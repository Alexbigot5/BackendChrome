# PostgreSQL connection string (provided automatically by Railway Postgres plugin)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Google Service Account credentials
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Paste the private key exactly as it appears in the JSON key file (newlines as \n)
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# Apify
APIFY_API_TOKEN=apify_api_...

# RapidAPI (fallback scraper if Apify fails)
RAPIDAPI_KEY=

# Frontend URL (for CORS)
FRONTEND_URL=https://your-vercel-domain.com

# Server port (Railway sets this automatically)
PORT=3000
